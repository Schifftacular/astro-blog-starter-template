---
const today = new Date();
---

<footer>
	<div class="footer-top-stripe"></div>
	<div class="footer-inner">
		<div class="footer-brand">
			<span class="footer-rns">RNS</span>
			<span class="footer-brand-name">Videomedia</span>
		</div>
		<p class="footer-tagline">East Coast equestrian eventing coverage.</p>
		<p class="footer-copy">
			&copy; {today.getFullYear()} RNS Videomedia. All rights reserved.
		</p>
	</div>
</footer>

<style>
	footer {
		background: #1A3A8C;
		color: rgba(255, 255, 255, 0.85);
		text-align: center;
	}

	.footer-top-stripe {
		height: 5px;
		background: linear-gradient(90deg, #C5192A 40%, #1A3A8C 40%);
	}

	.footer-inner {
		padding: 2.5em 1em 3em;
	}

	.footer-brand {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5em;
		margin-bottom: 0.5em;
	}

	.footer-rns {
		font-family: 'Barlow Condensed', sans-serif;
		font-weight: 900;
		font-size: 1.4em;
		letter-spacing: 0.06em;
		color: #fff;
		background: #C5192A;
		padding: 0.05em 0.4em 0.05em 0.3em;
		clip-path: polygon(0 0, 100% 0, 92% 100%, 0 100%);
	}

	.footer-brand-name {
		font-family: 'Barlow Condensed', sans-serif;
		font-weight: 700;
		font-size: 1.1em;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.9);
	}

	.footer-tagline {
		font-size: 0.85em;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.6);
		margin: 0 0 1.25em;
	}

	.footer-copy {
		font-size: 0.8em;
		color: rgba(255, 255, 255, 0.45);
		margin: 0;
	}
</style>
