---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<!-- Red accent stripe across top -->
	<div class="top-stripe"></div>
	<nav>
		<a href="/" class="site-wordmark" aria-label="RNS Videomedia — On Course">
			<span class="wordmark-rns">RNS</span>
			<span class="wordmark-divider"></span>
			<span class="wordmark-tagline">On Course</span>
		</a>
		<div class="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
	<!-- Navy band across bottom of header -->
	<div class="bottom-band"></div>
</header>

<style>
	header {
		margin: 0;
		padding: 0;
		background: #fff;
		position: relative;
	}

	/* Thin red racing stripe across very top */
	.top-stripe {
		height: 5px;
		background: linear-gradient(90deg, #C5192A 60%, #1A3A8C 60%);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 1.5em;
		height: 60px;
		gap: 1em;
	}

	/* ── Wordmark ── */
	.site-wordmark {
		display: flex;
		align-items: center;
		gap: 0.5em;
		text-decoration: none;
		flex-shrink: 0;
	}

	.wordmark-rns {
		font-family: 'Barlow Condensed', sans-serif;
		font-weight: 900;
		font-size: 1.6em;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: #fff;
		background: #C5192A;
		padding: 0.05em 0.35em 0.05em 0.3em;
		/* Diagonal right edge */
		clip-path: polygon(0 0, 100% 0, 92% 100%, 0 100%);
		line-height: 1.2;
	}

	.wordmark-divider {
		display: none; /* colour separation handled by clip-path */
	}

	.wordmark-tagline {
		font-family: 'Barlow Condensed', sans-serif;
		font-weight: 700;
		font-size: 1.1em;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #1A3A8C;
	}

	/* ── Nav links ── */
	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.25em;
	}

	/* Overrides for HeaderLink inside nav */
	.nav-links :global(a) {
		font-family: 'Barlow Condensed', sans-serif;
		font-weight: 700;
		font-size: 1em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding: 0.5em 0.75em;
		color: rgb(34, 41, 57);
		text-decoration: none;
		border-bottom: 3px solid transparent;
		transition: color 0.15s, border-color 0.15s;
	}

	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		color: #C5192A;
		border-bottom-color: #C5192A;
	}

	/* Navy accent band at bottom of header */
	.bottom-band {
		height: 3px;
		background: #1A3A8C;
	}

	@media (max-width: 480px) {
		.wordmark-tagline { display: none; }
	}
</style>
